def kind_for_slug(slug: str) -> str:
    """Route slug to kind by filename convention: experiment retrospectives have
    ``-experiment-`` (e.g. 2026-05-20-experiment-foo), review retrospectives have
    ``-review-`` (e.g. 2026-05-31-review-foo). Everything else is a tide."""
    if "-experiment-" in slug:
        return "experiment"
    if "-review-" in slug:
        return "review"
    return "tide"


def kind_config(kind: str) -> dict:
    if kind not in KIND_CONFIG:
        raise ValueError(f"unknown kind: {kind!r}")
    return KIND_CONFIG[kind]


def index_path_for(therisensea: Path, kind: str) -> Path:
    return therisensea / kind_config(kind)["index_relpath"]


def pages_root_for(therisensea: Path, kind: str) -> Path:
    return therisensea / kind_config(kind)["subdir"]


