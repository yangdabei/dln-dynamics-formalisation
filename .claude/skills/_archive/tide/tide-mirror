def find_sri_root() -> Path:
    if env := os.environ.get("SRI_ROOT"):
        return Path(env).resolve()
    here = Path(__file__).resolve().parent
    for d in [here] + list(here.parents):
        if (d / "lean").is_dir() and (d / "papers").is_dir() and (d / "projects").is_dir():
            return d
    sys.exit("tide-mirror: cannot locate SRI root (containing lean/, papers/, projects/)")


def find_therisensea(override: str | None) -> Path:
    if override:
        p = Path(override).resolve()
        if not p.is_dir():
            sys.exit(f"tide-mirror: --therisensea path does not exist: {p}")
        return p
    if env := os.environ.get("THERISENSEA_DIR"):
        return Path(env).resolve()
    sri = find_sri_root()
    candidates = [
        sri.parent / "therisensea",
        Path.home() / "timaeus" / "therisensea",
    ]
    for c in candidates:
        if c.is_dir():
            return c.resolve()
    sys.exit(
        "tide-mirror: cannot find therisensea clone. Set THERISENSEA_DIR or "
        "pass --therisensea <path>."
    )


def output_slug(source_slug: str) -> str:
    """Apply the mobius-surface "-tide-" stripping convention."""
    if "-tide-mobius-surface-" in source_slug:
        return source_slug.replace("-tide-", "-", 1)
    return source_slug


def find_tex(sri: Path, repo: str, slug: str) -> Path:
    slug = slug.removesuffix(".tex")
    candidate = sri / "lean" / repo / "retrospectives" / f"{slug}.tex"
    if not candidate.is_file():
        sys.exit(f"tide-mirror: no such file: {candidate}")
    return candidate


